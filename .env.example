# ================================================================
# Database (Neon Postgres or any PostgreSQL)
# ================================================================
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ================================================================
# Auth — REQUIRED
# ================================================================
# Session-signing secret. Generate with: openssl rand -hex 32
AUTH_SECRET=""

# ================================================================
# Initial bootstrap (used once by `pnpm db:bootstrap`)
# ================================================================
ADMIN_EMAIL="you@example.com"
ADMIN_NAME="Your Name"
ADMIN_PASSWORD=""  # leave empty to auto-generate
WORKSPACE_NAME="My Company"
WORKSPACE_SLUG="my-company"

# ================================================================
# App
# ================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
